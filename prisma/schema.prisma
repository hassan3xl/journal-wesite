generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String?
  role      String   @default("AUTHOR") // "ADMIN", "EDITOR", "REVIEWER", "AUTHOR"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  journals  Journal[] @relation("JournalCreator")
  articles  Article[]
  reviews   Review[]
}

model Journal {
  id          String   @id @default(cuid())
  title       String
  description String
  eissn       String?
  pissn       String?
  creatorId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator     User      @relation("JournalCreator", fields: [creatorId], references: [id])
  articles    Article[]
}

model Article {
  id          String   @id @default(cuid())
  title       String
  abstract    String
  content     String
  status      String   @default("SUBMITTED") // "DRAFT", "SUBMITTED", "UNDER_REVIEW", "ACCEPTED", "REJECTED", "PUBLISHED"
  authorId    String
  journalId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author      User      @relation(fields: [authorId], references: [id])
  journal     Journal   @relation(fields: [journalId], references: [id])
  reviews     Review[]
}

model Review {
  id          String   @id @default(cuid())
  articleId   String
  reviewerId  String
  status      String   @default("PENDING") // "PENDING", "COMPLETED"
  comments    String?
  decision    String?  // "ACCEPT", "REJECT", "REVISE"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  article     Article  @relation(fields: [articleId], references: [id])
  reviewer    User     @relation(fields: [reviewerId], references: [id])
}
